NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/footy501
# Generate with: openssl rand -base64 48 (must be 32+ characters)
JWT_SECRET=

# Google OAuth (optional - app works without these)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://footy501-production.up.railway.app/api/auth/google/callback
